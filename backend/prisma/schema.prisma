// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "views", "metrics", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, pg_stat_statements]
}

// USUARIOS
enum UserRole {
  ADMIN
  LOGISTICA // Logística (reception + inventory)
  OPERARIO_PICKING // Operario de Picking/Packing
  PRODUCCION // Producción (includes former LIDER_PRODUCCION)
  CARTERA // Cartera (billing/collections)
  DISTRIBUIDOR // Distribuidor (customers)
  CALIDAD // Calidad (quality/PQR)
  CONTABILIDAD // Contabilidad (accounting)
  COMERCIAL // Comercial (invoicing / sales)
  QUIMICO // Químico (premix, quality, microbiology, production oversight)
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  username        String   @unique
  password        String
  pin             String?  // Hashed 4-digit PIN for quick lock-screen auth
  name            String
  role            UserRole
  nit             String? // NIT or cédula for Siigo invoicing
  idType          String?  @default("13") // Siigo ID type: "13"=NIT, "12"=Cédula
  discountPercent Float?   @default(34.8) // Invoice discount % (default 34.8%)
  reteFuente      Boolean  @default(true) // true = Persona Jurídica (aplica Rete 2.5%), false = Persona Natural

  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  distributorOrders Order[]            @relation("DistributorOrders")
  approvedOrders    Order[]            @relation("OrderApprover")
  pickedOrders      Order[]            @relation("OrderPicker")
  scannedItems      OrderPickingItem[] @relation("OrderScanner")
  productionOrders  ProductionOrder[]
  auditLogs         AuditLog[]

  // PQR Relations
  createdPQRs          PQR[]                 @relation("PQRCreator")
  managedPQRs          PQR[]                 @relation("PQRManager")
  recallLotCollections RecallLotCollection[]

  // Micro Analysis Relations
  microSamples         MicroSample[]        @relation("MicroSampleTaker")
  microScheduleEntries MicroScheduleEntry[] @relation("MicroScheduleEntryCreator")
  microInternalLogs    MicroInternalLog[]   @relation("MicroInternalLogRecorder")

  // Assembly System Relations
  createdTemplates  AssemblyTemplate[]        @relation("TemplateCreator")
  updatedTemplates  AssemblyTemplate[]        @relation("TemplateUpdater")
  createdFormulas   Formula[]                 @relation("FormulaCreator")
  updatedFormulas   Formula[]                 @relation("FormulaUpdater")
  approvedFormulas  Formula[]                 @relation("FormulaApprover")
  createdNotes      AssemblyNote[]            @relation("NoteCreator")
  executedNotes     AssemblyNote[]            @relation("NoteExecutor")
  completedNotes    AssemblyNote[]            @relation("NoteCompleter")
  consumedItems     AssemblyNoteItem[]        @relation("ItemConsumer")
  capturedVariables AssemblyProcessVariable[] @relation("VariableCaptor")
  qualityChecks     AssemblyQualityCheck[]    @relation("QualityChecker")
  rpaExecutions     RpaExecution[]

  // Procurement Relations
  createdPurchaseOrders  PurchaseOrder[]  @relation("POCreator")
  approvedPurchaseOrders PurchaseOrder[]  @relation("POApprover")
  paidPurchaseOrders     PurchaseOrder[]  @relation("POPayer")
  receivedReceptions     Reception[]      @relation("ReceptionReceiver")
  validatedReceptions    Reception[]      @relation("ReceptionValidator")
  lotConsumptions        LotConsumption[] @relation("LotConsumer")
  zoneTransfers          ZoneTransfer[]   @relation("ZoneTransferUser")

  // Handoff Relations
  createdHandoffs  ProductHandoff[] @relation("HandoffCreator")
  receivedHandoffs ProductHandoff[] @relation("HandoffReceiver")

  // Cart Reservation
  cartReservations CartReservation[] @relation("CartDistributor")

  // Finished Product Lot Tracking
  finishedLotTransfers FinishedLotTransfer[] @relation("FinishedLotTransferUser")

  // Physical Inventory Count
  physicalCounts        PhysicalCount[]        @relation("PhysicalCountUser")
  inventoryCountSessions InventoryCountSession[] @relation("InventoryCountCreator")


  // Sanitation (POES)
  performedSanitations SanitationRecord[] @relation("PerformedSanitation")
  verifiedSanitations  SanitationRecord[] @relation("VerifiedSanitation")

  @@index([email])
  @@index([role, active])
  @@map("users")
}

// PRODUCTOS
enum ProductType {
  PERLA_EXPLOSIVA
  SYRUP
  BASE_CITRICA
  MATERIA_PRIMA
}

enum ProductClassification {
  PRODUCTO_TERMINADO
  MATERIA_PRIMA
  PRODUCTO_EN_PROCESO
}

model InventoryGroup {
  id          String    @id @default(uuid())
  siigoId     String    @unique
  name        String
  type        String
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([siigoId])
  @@map("inventory_groups")
}

model Product {
  id             String                 @id @default(uuid())
  siigoId        String                 @unique
  sku            String                 @unique
  barcode        String                 @unique
  name           String
  type           ProductType
  classification ProductClassification?
  accountGroup   Int? // SIIGO account group classification
  flavor         String?
  size           String?
  unit           String

  groupId String
  group   InventoryGroup @relation(fields: [groupId], references: [id])

  currentStock        Float    @default(0)
  productionZoneStock Float    @default(0) // Stock en zona de producción
  price               Float    @default(0)
  taxClassification   String?
  taxIncluded         Boolean?
  taxes               Json?
  warehouses          Json?
  active              Boolean  @default(true)

  minimumStock Float     @default(0)
  lastSync     DateTime?

  avgDailyConsumption Float   @default(0)
  dailyVelocity       Float   @default(0) // Calculated from Data Mining
  daysOfStock         Float   @default(0)
  velocityTrend       String?

  // Replenishment Config
  packSize  Float @default(1)
  costPrice Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boms               BOM[]
  bomComponents      BOMItem[]            @relation("ComponentProduct")
  inventoryAlternate InventoryAlternate?
  consumptionHistory ConsumptionHistory[]
  orderItems         OrderItem[]
  productionOrders   ProductionOrder[]
  productionBatches  ProductionBatch[]
  batchTargets       BatchOutputTarget[]

  // Assembly System Relations
  templates          AssemblyTemplate[]           @relation("ProductTemplate")
  formulas           Formula[]                    @relation("ProductFormula")
  stageOutputs       AssemblyTemplateStage[]      @relation("StageOutput")
  stageInputs        AssemblyTemplateStageInput[] @relation("StageInputProduct")
  formulaIngredients FormulaItem[]                @relation("FormulaIngredient")
  assemblyNotes      AssemblyNote[]               @relation("AssemblyNoteProduct")
  assemblyComponents AssemblyNoteItem[]           @relation("AssemblyComponent")
  movements          Movement[]
  pqrItems           PQRItem[]

  // Procurement Relations
  purchaseOrderItems PurchaseOrderItem[] @relation("POItemProduct")
  materialLots       MaterialLot[]       @relation("LotProduct")
  zoneTransfers      ZoneTransfer[]      @relation("ZoneTransferProduct")
  productPackaging   ProductPackaging?   @relation("PackagingProduct")

  // Handoff Relations
  handoffItems HandoffItem[] @relation("HandoffProduct")

  // Cart Reservation
  cartReservations CartReservation[] @relation("CartProduct")

  // Finished Product Lot Tracking
  finishedLotStocks    FinishedLotStock[]    @relation("FinishedLotProduct")
  finishedLotTransfers FinishedLotTransfer[] @relation("FinishedLotTransferProduct")
  pendingBoxes         PendingBox[]          @relation("PendingBoxProduct")
  physicalCountItems   PhysicalCountItem[]   @relation("PhysicalCountProduct")
  inventoryCountLines  InventoryCountLine[]  @relation("InventoryCountProduct")


  @@index([siigoId])
  @@index([barcode])
  @@index([type, groupId])
  @@index([daysOfStock])
  @@map("products")
}

// BOM
model BOM {
  id            String    @id @default(uuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  version       Int       @default(1)
  active        Boolean   @default(true)
  stage         Int
  stageName     String
  expectedYield Float?
  items         BOMItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([productId, version, stage])
  @@index([productId, active])
  @@map("bom")
}

model BOMItem {
  id          String  @id @default(uuid())
  bomId       String
  bom         BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("ComponentProduct", fields: [componentId], references: [id])
  quantity    Float
  unit        String

  @@index([bomId])
  @@index([componentId])
  @@map("bom_items")
}

// INVENTARIO ALTERNO
model InventoryAlternate {
  id           String   @id @default(uuid())
  productId    String   @unique
  product      Product  @relation(fields: [productId], references: [id])
  reservedQty  Float    @default(0)
  availableQty Float    @default(0)
  lastUpdated  DateTime @updatedAt

  @@map("inventory_alternate")
}

model CartReservation {
  id            String   @id @default(uuid())
  distributorId String
  distributor   User     @relation("CartDistributor", fields: [distributorId], references: [id])
  productId     String
  product       Product  @relation("CartProduct", fields: [productId], references: [id])
  quantity      Float
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@unique([distributorId, productId])
  @@index([productId])
  @@index([expiresAt])
  @@map("cart_reservations")
}

// CONSUMO
model ConsumptionHistory {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  date      DateTime
  consumed  Float
  source    String
  reference String?
  createdAt DateTime @default(now())

  @@index([productId, date])
  @@map("consumption_history")
}

// PEDIDOS
enum OrderStatus {
  PENDING // Distribuidor creó el pedido
  APPROVED // Director Logístico aprobó
  IN_PICKING // Operario está separando
  READY // Listo para despacho
  INVOICED // Facturado
  DISPATCHED // Despachado
  DELIVERED // Entregado
  CANCELLED // Cancelado por distribuidor
  REJECTED // Rechazado por director
}

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique
  distributorId     String
  distributor       User        @relation("DistributorOrders", fields: [distributorId], references: [id])
  status            OrderStatus @default(PENDING)
  completionPercent Int         @default(0)
  items             OrderItem[]

  // Picking Progress
  pickingProgress  Int       @default(0) // 0-100%
  packingMode      String?   @map("packing_mode") // 'NORMAL' or 'EVEREST'
  pickingStartedAt DateTime?
  pickingStartedBy String?
  picker           User?     @relation("OrderPicker", fields: [pickingStartedBy], references: [id])

  // Distributor notes
  notes String?

  // Approval workflow
  approvedBy     String?
  approver       User?     @relation("OrderApprover", fields: [approvedBy], references: [id])
  approvedAt     DateTime?
  rejectedReason String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  readyAt      DateTime?
  invoicedAt   DateTime?
  dispatchedAt DateTime?
  deliveredAt  DateTime?

  siigoInvoiceId      String?
  invoiceNumber       String?
  invoicePdfUrl       String?
  accountStatementUrl String?
  invoicedBy          String?
  trackingGuide       String?
  dispatchNotes       String?

  // Enhanced dispatch fields
  // @deprecated: usar driverId cuando sea posible. Estos campos se mantienen para el PDF de guía.
  driverName           String?
  licensePlate         String?
  driverCedula         String?
  driverPhone          String?

  // FK a Driver (Fase 3 normalización) — se popula en backfill y en nuevo dispatch
  driverId    String?  @map("driver_id")
  driver      Driver?  @relation("OrderDriver", fields: [driverId], references: [id], onDelete: SetNull)

  amountPaid           Float?
  totalWeightKg        Float?
  dispatchTime         String?
  destination          String?
  destinationCity      String?  @map("destination_city")
  receiverName         String?  @map("receiver_name")
  receiverPhone        String?  @map("receiver_phone")
  transportGuideNumber String? @unique
  signedGuideUrl       String? @map("signed_guide_url")

  @@index([distributorId])
  @@index([status, createdAt])
  @@index([approvedBy])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  requestedQty Float
  allocatedQty Float   @default(0)
  pendingQty   Float
  sortOrder    Int     @default(0) @map("sort_order")

  pickingItems OrderPickingItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderPickingItem {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // QR Scan Data
  productCode    String
  barcode        String
  productName    String
  unitsPerBox    Int
  lotNumber      String
  expirationDate DateTime

  // Picking Details
  scannedQty Int      @default(0)
  scannedAt  DateTime @default(now())
  scannedBy  String
  scanner    User     @relation("OrderScanner", fields: [scannedBy], references: [id])

  @@index([orderItemId])
  @@index([scannedBy])
  @@map("order_picking_items")
}

// CONDUCTORES (reusable driver data)
model Driver {
  id           String   @id @default(uuid())
  name         String
  cedula       String?  @unique
  phone        String?
  licensePlate String?
  usageCount   Int      @default(1)
  lastUsed     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[] @relation("OrderDriver")

  @@index([name])
  @@map("drivers")
}

// PRODUCCIÓN
enum ProductionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrder {
  id               String            @id @default(uuid())
  orderNumber      String            @unique
  productId        String
  product          Product           @relation(fields: [productId], references: [id])
  scheduledDate    DateTime
  totalBatches     Int
  completedBatches Int               @default(0)
  status           ProductionStatus  @default(SCHEDULED)
  createdById      String
  createdBy        User              @relation(fields: [createdById], references: [id])
  batches          ProductionBatch[]

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([scheduledDate, status])
  @@index([productId])
  @@map("production_orders")
}

enum BatchStatus {
  PENDING
  STAGE_1_BASE
  STAGE_2_JARABE
  STAGE_3_ESFERIFICACION
  STAGE_4_PRODUCTO_FINAL
  LABELING
  COMPLETED
  FAILED
}

model ProductionBatch {
  id          String @id @default(uuid())
  batchNumber String @unique

  // Optional links to legacy ProductionOrder system
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id], onDelete: SetNull)
  productId         String?
  product           Product?         @relation(fields: [productId], references: [id])

  // New Schedulling Fields
  flavor         String? // For Liquipops Batches (e.g. "Fresa")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  notes          String? // For auxiliary event descriptions or instructions

  // Weight Management
  baseWeight           Float? // Input Kg (e.g. 120kg)
  projectedTotalWeight Float? // Output Kg (e.g. 200kg)

  currentStage Int         @default(1)
  status       BatchStatus @default(PENDING)
  // lotNumbers eliminado (Fase 7) — consultar FinishedLotStock WHERE batchId = X
  // stage1-4AssemblyId eliminados (Fase 7) — consultar AssemblyNote WHERE productionBatchId = X AND stageOrder = N

  expectedOutput     Float?
  actualOutput       Float?
  containersProduced Int    @default(0)
  containersLabeled  Int    @default(0)

  qrCodes           QRCode[]
  outputTargets     BatchOutputTarget[]
  assemblyNotes     AssemblyNote[]
  finishedLotStocks FinishedLotStock[]  @relation("FinishedLotBatch")

  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime? // Fabrication + 9 months (INVIMA)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productionOrderId])
  @@index([batchNumber])
  @@index([status])
  @@index([flavor])
  @@map("production_batches")
}

model BatchOutputTarget {
  id      String          @id @default(uuid())
  batchId String
  batch   ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  plannedUnits    Int   @default(0)
  plannedWeightKg Float @default(0)

  // Resultados reales de producción (poblados al completar CONTEO/EMPAQUE)
  actualUnits   Int @default(0) // Total contado (aprobados + defectuosos)
  approvedUnits Int @default(0) // Aprobados para inventario
  defectiveUnits Int @default(0) // Rechazados / defectuosos
  contramuestraQty Int @default(0) // Contra-muestras para seguimiento de vida útil

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@map("batch_output_targets")
}

// QR
model QRCode {
  id          String          @id @default(uuid())
  code        String          @unique
  batchId     String
  batch       ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productName String
  barcode     String
  lotNumber   String
  expiryDate  DateTime
  scanned     Boolean         @default(false)
  scannedAt   DateTime?
  scannedBy   String?
  createdAt   DateTime        @default(now())

  @@index([batchId])
  @@index([code])
  @@map("qr_codes")
}

// AUDITORÍA
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// SystemConfig eliminado (Fase 1 normalización) — usar SystemSettings

// WEBHOOKS
model WebhookLog {
  id          String    @id @default(uuid())
  event       String
  payload     Json
  processed   Boolean   @default(false)
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([event, processed])
  @@map("webhook_logs")
}

// CONFIGURACIÓN DEL SISTEMA
model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique // e.g., 'PRODUCTION_CONFIG'
  value       Json // Stores structure: { targetDays: 8, minStockDays: 15, alertYellow: 12, alertRed: 3 }
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

// ============================================
// ENUMS DE NOTAS DE ENSAMBLE (Fase 2 normalización)
// ============================================

enum AssemblyNoteStatus {
  PENDING
  EXECUTING
  COMPLETED
  FAILED
}

// ============================================
// SISTEMA DE ENSAMBLE - PLANTILLAS
// ============================================

// Tipos de proceso configurables
model ProcessType {
  id               String   @id @default(uuid())
  code             String   @unique
  name             String
  category         String // 'STANDARD', 'SPECIAL'
  icon             String?
  color            String?
  parametersSchema Json?    @map("parameters_schema")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  stages        AssemblyTemplateStage[]
  assemblyNotes AssemblyNote[]

  @@map("process_types")
}

// Plantillas de ensamble
model AssemblyTemplate {
  id           String  @id @default(uuid())
  templateCode String  @unique @map("template_code")
  templateName String  @map("template_name")
  productId    String  @map("product_id")
  product      Product @relation("ProductTemplate", fields: [productId], references: [id])

  version          Int                @default(1)
  isActive         Boolean            @default(true) @map("is_active")
  parentTemplateId String?            @map("parent_template_id")
  parentTemplate   AssemblyTemplate?  @relation("TemplateVersion", fields: [parentTemplateId], references: [id])
  childVersions    AssemblyTemplate[] @relation("TemplateVersion")

  description String?
  totalStages Int     @map("total_stages")

  stages             AssemblyTemplateStage[]
  referencedByStages AssemblyTemplateStage[] @relation("SubTemplateStage")
  assemblyNotes      AssemblyNote[]

  createdById String?  @map("created_by")
  createdBy   User?    @relation("TemplateCreator", fields: [createdById], references: [id])
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("TemplateUpdater", fields: [updatedById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([productId, version])
  @@index([productId])
  @@index([isActive])
  @@map("assembly_templates")
}

// Etapas de la plantilla
model AssemblyTemplateStage {
  id         String           @id @default(uuid())
  templateId String           @map("template_id")
  template   AssemblyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  stageOrder Int    @map("stage_order")
  stageName  String @map("stage_name")

  processTypeId     String      @map("process_type_id")
  processType       ProcessType @relation(fields: [processTypeId], references: [id])
  processParameters Json?       @map("process_parameters")

  outputProductId      String?  @map("output_product_id")
  outputProduct        Product? @relation("StageOutput", fields: [outputProductId], references: [id])
  outputClassification String?  @map("output_classification")

  specialInstructions String? @map("special_instructions")

  subTemplateId String?           @map("sub_template_id")
  subTemplate   AssemblyTemplate? @relation("SubTemplateStage", fields: [subTemplateId], references: [id])

  inputs        AssemblyTemplateStageInput[]
  assemblyNotes AssemblyNote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([templateId, stageOrder])
  @@index([templateId])
  @@map("assembly_template_stages")
}

// Inputs de cada etapa
model AssemblyTemplateStageInput {
  id      String                @id @default(uuid())
  stageId String                @map("stage_id")
  stage   AssemblyTemplateStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  inputType String @map("input_type") // 'RAW_MATERIAL', 'SUB_ASSEMBLY', 'FROM_PREVIOUS_STAGE'

  productId String?  @map("product_id")
  product   Product? @relation("StageInputProduct", fields: [productId], references: [id])

  fromStageOrder Int? @map("from_stage_order")

  quantityPerUnit Float  @map("quantity_per_unit")
  unit            String

  displayOrder      Int?    @map("display_order")
  aggregateOnRepeat Boolean @default(false) @map("aggregate_on_repeat")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([stageId])
  @@map("assembly_template_stage_inputs")
}

// ============================================
// SISTEMA DE FORMULACIONES
// ============================================

model Formula {
  id          String @id @default(uuid())
  formulaCode String @unique @map("formula_code")
  formulaName String @map("formula_name")

  productId String  @map("product_id")
  product   Product @relation("ProductFormula", fields: [productId], references: [id])

  version         Int       @default(1)
  isActive        Boolean   @default(true) @map("is_active")
  parentFormulaId String?   @map("parent_formula_id")
  parentFormula   Formula?  @relation("FormulaVersion", fields: [parentFormulaId], references: [id])
  childVersions   Formula[] @relation("FormulaVersion")

  baseUnit                String @map("base_unit")
  baseQuantity            Float  @default(1.0) @map("base_quantity")
  expectedYieldPercentage Float  @default(100.0) @map("expected_yield_percentage")

  description String?
  notes       String?

  items FormulaItem[]
  cost  FormulaCost?

  createdById  String?   @map("created_by")
  createdBy    User?     @relation("FormulaCreator", fields: [createdById], references: [id])
  updatedById  String?   @map("updated_by")
  updatedBy    User?     @relation("FormulaUpdater", fields: [updatedById], references: [id])
  approvedById String?   @map("approved_by")
  approvedBy   User?     @relation("FormulaApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([productId, version])
  @@index([productId])
  @@index([isActive])
  @@map("formulas")
}

model FormulaItem {
  id        String  @id @default(uuid())
  formulaId String  @map("formula_id")
  formula   Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  ingredientId   String  @map("ingredient_id")
  ingredient     Product @relation("FormulaIngredient", fields: [ingredientId], references: [id])
  ingredientType String  @map("ingredient_type")

  quantity   Float
  unit       String
  percentage Float?

  additionOrder Int? @map("addition_order")

  minQuantity Float? @map("min_quantity")
  maxQuantity Float? @map("max_quantity")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([formulaId])
  @@index([ingredientId])
  @@map("formula_items")
}

model FormulaCost {
  id        String  @id @default(uuid())
  formulaId String  @unique @map("formula_id")
  formula   Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  materialCost Float @map("material_cost")
  laborCost    Float @default(0) @map("labor_cost")
  overheadCost Float @default(0) @map("overhead_cost")
  totalCost    Float @map("total_cost")
  costPerUnit  Float @map("cost_per_unit")

  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@map("formula_costs")
}

// ============================================
// NOTAS DE ENSAMBLE
// ============================================

model AssemblyNote {
  id         String @id @default(uuid())
  noteNumber String @unique @map("note_number")

  productionBatchId String          @map("production_batch_id")
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id])

  productId String  @map("product_id")
  product   Product @relation("AssemblyNoteProduct", fields: [productId], references: [id])

  templateId String?                @map("template_id")
  template   AssemblyTemplate?      @relation(fields: [templateId], references: [id])
  stageId    String?                @map("stage_id")
  stage      AssemblyTemplateStage? @relation(fields: [stageId], references: [id])
  stageOrder Int                    @map("stage_order")
  stageName  String                 @map("stage_name")

  targetQuantity Float  @map("target_quantity")
  actualQuantity Float? @map("actual_quantity")
  unit           String

  status AssemblyNoteStatus @default(PENDING)

  processTypeId     String?      @map("process_type_id")
  processType       ProcessType? @relation(fields: [processTypeId], references: [id])
  processParameters Json?        @map("process_parameters")
  actualParameters  Json?        @map("actual_parameters")

  batchCode String? @map("batch_code")

  notes        String?
  observations String?

  items            AssemblyNoteItem[]
  processVariables AssemblyProcessVariable[]
  qualityChecks    AssemblyQualityCheck[]
  rpaExecutions    RpaExecution[]
  lotConsumptions  LotConsumption[] @relation("NoteConsumptions")

  createdById   String?   @map("created_by")
  createdBy     User?     @relation("NoteCreator", fields: [createdById], references: [id])
  executedById  String?   @map("executed_by")
  executedBy    User?     @relation("NoteExecutor", fields: [executedById], references: [id])
  completedById String?   @map("completed_by")
  completedBy   User?     @relation("NoteCompleter", fields: [completedById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([productionBatchId])
  @@index([productId])
  @@index([status])
  @@map("assembly_notes")
}

model AssemblyNoteItem {
  id             String       @id @default(uuid())
  assemblyNoteId String       @map("assembly_note_id")
  assemblyNote   AssemblyNote @relation(fields: [assemblyNoteId], references: [id], onDelete: Cascade)

  componentId   String  @map("component_id")
  component     Product @relation("AssemblyComponent", fields: [componentId], references: [id])
  componentType String  @map("component_type")

  plannedQuantity Float  @map("planned_quantity")
  actualQuantity  Float? @map("actual_quantity")
  unit            String

  lotNumber String? @map("lot_number")

  consumed     Boolean   @default(false)
  consumedAt   DateTime? @map("consumed_at")
  consumedById String?   @map("consumed_by")
  consumedBy   User?     @relation("ItemConsumer", fields: [consumedById], references: [id])

  notes String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([assemblyNoteId])
  @@index([componentId])
  @@map("assembly_note_items")
}

model AssemblyProcessVariable {
  id             String       @id @default(uuid())
  assemblyNoteId String       @map("assembly_note_id")
  assemblyNote   AssemblyNote @relation(fields: [assemblyNoteId], references: [id], onDelete: Cascade)

  variableName  String  @map("variable_name")
  variableValue String  @map("variable_value")
  variableUnit  String? @map("variable_unit")

  expectedMin   Float?  @map("expected_min")
  expectedMax   Float?  @map("expected_max")
  isWithinRange Boolean @default(true) @map("is_within_range")

  capturedAt   DateTime @default(now()) @map("captured_at")
  capturedById String?  @map("captured_by")
  capturedBy   User?    @relation("VariableCaptor", fields: [capturedById], references: [id])

  @@index([assemblyNoteId])
  @@map("assembly_process_variables")
}

model AssemblyQualityCheck {
  id             String       @id @default(uuid())
  assemblyNoteId String       @map("assembly_note_id")
  assemblyNote   AssemblyNote @relation(fields: [assemblyNoteId], references: [id], onDelete: Cascade)

  checkType String @map("check_type")
  checkName String @map("check_name")

  resultValue   String? @map("result_value")
  expectedValue String? @map("expected_value")

  passed Boolean
  notes  String?

  photoUrls String[] @map("photo_urls")

  checkedById String?  @map("checked_by")
  checkedBy   User?    @relation("QualityChecker", fields: [checkedById], references: [id])
  checkedAt   DateTime @default(now()) @map("checked_at")

  @@index([assemblyNoteId])
  @@map("assembly_quality_checks")
}

// ============================================
