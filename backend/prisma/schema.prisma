// ============================================
// FACTURACIÓN SIIGO — DATOS EXACTOS PARA INFORMES
// ============================================

model SiigoInvoiceItem {
  id                String   @id @default(cuid())
  invoiceNumber     Int      @map("invoice_number")
  documentPrefix    String   @map("document_prefix")        // "FV-1" o "FV-2"
  invoiceDate       DateTime @map("invoice_date")
  customerNit       String   @map("customer_nit")
  customerName      String   @map("customer_name")
  itemCode          String   @map("item_code")              // SKU del producto
  itemDescription   String   @map("item_description")
  quantity          Float
  unitPrice         Float    @map("unit_price")              // precio base SIN IVA (de Siigo)
  discountPercent   Float    @default(0) @map("discount_percent")
