model ShiftHandoverRecord {
  id                   String         @id @default(uuid())
  weekId               String         @map("week_id")
  publishedAtSnapshot  DateTime?      @map("published_at_snapshot")
  area                 String
  operationalDate      DateTime       @map("operational_date") @db.Date
  outgoingShift        String         @map("outgoing_shift")
  incomingShift        String         @map("incoming_shift")
  outgoingLeaderId     String?        @map("outgoing_leader_id")
  outgoingLeaderAt     DateTime?      @map("outgoing_leader_at")
  incomingLeaderId     String?        @map("incoming_leader_id")
  incomingLeaderAt     DateTime?      @map("incoming_leader_at")
  outgoingParticipants Json?          @map("outgoing_participants")
  incomingParticipants Json?          @map("incoming_participants")
  checklist            Json?
  pendingTasks         String?        @map("pending_tasks")
  incidents            String?
  observations         String?
  supervisorId         String?        @map("supervisor_id")
  supervisorAt         DateTime?      @map("supervisor_at")
  status               HandoverStatus @default(PENDING)
  rejectionReason      String?        @map("rejection_reason")
  graceDeadline        DateTime?      @map("grace_deadline")
  allSignedAt          DateTime?      @map("all_signed_at")
  forcedCompleteBy     String?        @map("forced_complete_by")
  forcedCompleteAt     DateTime?      @map("forced_complete_at")
  forcedReason         String?        @map("forced_reason")
  auditLog             Json?          @map("audit_log")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at")

  week           ShiftWeek                @relation(fields: [weekId], references: [id])
  outgoingLeader User?                    @relation("HandoverOutgoingLeader", fields: [outgoingLeaderId], references: [id])
  incomingLeader User?                    @relation("HandoverIncomingLeader", fields: [incomingLeaderId], references: [id])
  supervisor     User?                    @relation("HandoverSupervisor", fields: [supervisorId], references: [id])
  forcedByUser   User?                    @relation("HandoverForcedBy", fields: [forcedCompleteBy], references: [id])
  signatures     ShiftHandoverSignature[]

  @@unique([weekId, operationalDate, area, outgoingShift])
  @@index([operationalDate, area])
  @@index([status])
  @@index([outgoingLeaderId])
  @@index([incomingLeaderId])
  @@map("shift_handover_records")
}

model ShiftHandoverSignature {
  id         String   @id @default(uuid())
  handoverId String   @map("handover_id")
  employeeId String   @map("employee_id")
  userId     String   @map("user_id")
  participantGroup ShiftHandoverParticipantGroup @default(OUTGOING) @map("participant_group")
  signedAt   DateTime @default(now()) @map("signed_at")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  handover ShiftHandoverRecord @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  employee ShiftEmployee       @relation("HandoverEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  user     User                @relation("HandoverSigner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([handoverId, userId])
  @@index([handoverId])
  @@map("shift_handover_signatures")
}

model ShiftHandoverChecklist {
  id        String   @id @default(uuid())
  area      String
  label     String
  fieldType String   @default("boolean") @map("field_type")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([area, active])
  @@map("shift_handover_checklists")
}

enum HandoverStatus {
