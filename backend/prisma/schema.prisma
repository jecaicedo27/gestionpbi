  ivaValue          Float    @default(0) @map("iva_value")
  ultraPercent      Float    @default(0) @map("ultra_percent")
  ultraValue        Float    @default(0) @map("ultra_value")
  bebidasValue      Float    @default(0) @map("bebidas_value")
  lineTotal         Float    @map("line_total")              // total exacto de Siigo
  syncedAt          DateTime @default(now()) @map("synced_at")

  @@unique([invoiceNumber, documentPrefix, itemCode, quantity], name: "unique_invoice_item")
  @@index([invoiceDate])
  @@index([customerNit])
  @@map("siigo_invoice_items")
}

// ============================================
// SISTEMA DE PQR / GARANTÍAS
// ============================================

enum PQRType {
  CALIDAD
  FALTANTE
  TROCADO
  AVERIA_TRANSPORTE
}

enum PQRStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  PROCESSED
}

// New Enums for Advanced Workflow
enum PQRStage {
  PENDING_REVIEW // 1. Calidad revisa
  PENDING_BILLING // 2. Contabilidad hace Nota Crédito
  PENDING_INVOICE // 3. Contabilidad hace Factura (solo Reposición Física)
  PENDING_LOGISTICS // 4. Logística despacha (solo Reposición Física)
  DISPATCHED // 5. Despachado
  COMPLETED // Final
  REJECTED // Rechazado en cualquier etapa
}

enum PQRRefundMethod {
  WALLET_BALANCE // Saldo a Favor
  PHYSICAL_REPLACEMENT // Reposición Física
}

model PQR {
  id           String @id @default(uuid())
  ticketNumber String @unique // e.g. PQR-PBI-001
  userId       String
  user         User   @relation("PQRCreator", fields: [userId], references: [id])

  // Workflow Fields
  status       PQRStatus        @default(PENDING) // General Status
  stage        PQRStage         @default(PENDING_REVIEW) // Granular Workflow Stage
  refundMethod PQRRefundMethod?

  // Internal PQR fields
  isInternal          Boolean   @default(false) // true = PQR Interno (planta)
  origin              String? // DETERIORO_PLANTA | DEFECTO_FABRICACION
  daysAfterProduction Int? // Días desde fabricación
  adjustmentDocUrl    String? // PDF ajuste de inventario
  pendingAdjustment   Boolean   @default(false) // Admin: ajuste de daños pendiente luego de NC
  adjustmentDoneAt    DateTime? // Cuándo se marcó el ajuste como hecho
  adjustmentNotes     String? // Observaciones del ajuste de inventario

  // Legacy/Simple fields (Keep for backward compatibility during dev, but logic moves to PQRItem)
  type PQRType? // Optional now, usually at Item level but can be Global

  // Resolution Details
  managedById              String?
  managedBy                User?   @relation("PQRManager", fields: [managedById], references: [id])
  rejectionReason          String?
  internalNotes            String?
  technicalResponse        String?
  reportedByName           String? // Subdistribuidor / Cliente final reportado por el distribuidor
  reportedByNameNormalized String?

  // Billing/Logistics Links
  replacementOrderId  String? // ID de la orden de reposición en Siigo (Factura)
  creditNoteId        String? // ID de la Nota Crédito en Siigo
  creditNoteUrl       String? // URL of uploaded credit note PDF
  accountStatementUrl String? // URL of uploaded account statement PDF
  invoiceUrl          String? // URL of uploaded invoice PDF

  // Logistics Evidence
  dispatchEvidenceUrl String? // URL of dispatch photo/file

  items PQRItem[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([userId])
  @@index([userId, reportedByNameNormalized])
  @@index([status])
  @@index([ticketNumber])
  @@map("pqr")
}

model PQRItem {
  id    String @id @default(uuid())
  pqrId String
  pqr   PQR    @relation(fields: [pqrId], references: [id], onDelete: Cascade)

  type      PQRType  @default(CALIDAD)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  quantity    Float
  unit        String
  lotNumber   String?
  description String

  evidence PQREvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pqrId])
  @@map("pqr_items")
}

model PQREvidence {
  id        String   @id @default(uuid())
  // Link to Item (Preferred)
  pqrItemId String?
  pqrItem   PQRItem? @relation(fields: [pqrItemId], references: [id], onDelete: Cascade)

  // Legacy Link to Header (Optional)
  pqrId String?

  url       String
  type      String // IMAGE, VIDEO
  createdAt DateTime @default(now())

  @@index([pqrItemId])
  @@map("pqr_evidence")
}

model RecallLotCollection {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lotNumber   String   @map("lot_number")
  collectedAt DateTime @default(now()) @map("collected_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, lotNumber])
  @@index([lotNumber])
  @@map("recall_lot_collections")
}

// RPA Bot Execution History
model RpaExecution {
  id            String @id @default(uuid())
  executionType String @map("execution_type") // 'SIIGO_ASSEMBLY'
  status        String @default("RUNNING") // RUNNING, SUCCESS, FAILED

  // Input parameters
  productName  String  @map("product_name")
  quantity     Float
  assemblyType String? @map("assembly_type") // 'proceso', 'terminado'
  observations String?

  // Result
  siigoNoteCode  String? @map("siigo_note_code") // Code returned by Siigo
  siigoUrl       String? @map("siigo_url")
  screenshotPath String? @map("screenshot_path")
  errorMessage   String? @map("error_message")
  logs           Json? // Full execution logs

  // Links
  assemblyNoteId String?       @map("assembly_note_id")
  assemblyNote   AssemblyNote? @relation(fields: [assemblyNoteId], references: [id])
  triggeredById  String?       @map("triggered_by_id")
  triggeredBy    User?         @relation(fields: [triggeredById], references: [id])

  // Timing
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")

  @@index([status])
  @@index([assemblyNoteId])
  @@map("rpa_executions")
}

// ============================================
// ANÁLISIS MICROBIOLÓGICOS (LIMS Light)
// ============================================

model MicroSamplingPoint {
  id                        String  @id @default(uuid())
  code                      String  @unique // ALG-PRE, COMP, ESF-INY, etc.
  zoneCode                  String  @unique @map("zone_code")
  name                      String // Alginato Pre-Pasteurización
  description               String?
  processArea               String? // Pasteurización, Esferificación, Materias Primas, Ambiente
  isEnvironmental           Boolean @default(false)
  zoneName                  String? @map("zone_name")
  allowedLaboratoryProfiles Json?   @default("[]") @map("allowed_laboratory_profiles")
  allowedWorkContexts       Json?   @default("[]") @map("allowed_work_contexts")
  allowedShifts             Json?   @default("[]") @map("allowed_shifts")
  allowedWorkflowTypes      Json?   @default("[]") @map("allowed_workflow_types")
  defaultLaboratoryProfile  String? @map("default_laboratory_profile")
  defaultWorkContext        String? @map("default_work_context")
  defaultShift              String? @map("default_shift")
  defaultWorkflowType       String  @default("EXTERNAL") @map("default_workflow_type")
  defaultAssignedLab        String? @map("default_assigned_lab")
  sortOrder                 Int     @default(0)
  isActive                  Boolean @default(true)

  schedules       MicroSchedule[]
  samples         MicroSample[]
  scheduleEntries MicroScheduleEntry[]

  createdAt DateTime @default(now())

  @@map("micro_sampling_points")
}

model MicroParameter {
  id            String  @id @default(uuid())
  code          String  @unique // ENTEROBACTERIAS, MOHOS_LEVADURAS, etc.
  name          String // Recuento de Enterobacterias
  unit          String // UFC/g o mL
  method        String? // ISO 21528-2:2017
  specMin       Float? // m value (acceptable limit)
  specMax       Float? // M value (marginal limit)
  specText      String? // "Ausente /25g" (for qualitative params)
  regulatoryRef String? // Res. 1407/22 MinSalud
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  results                 MicroResult[]
  scheduleEntryParameters MicroScheduleEntryParameter[]
  sampleParameters        MicroSampleParameter[]
  logReadings             MicroLogReading[]

  createdAt DateTime @default(now())

  @@map("micro_parameters")
}

model MicroSchedule {
  id              String             @id @default(uuid())
  samplingPointId String
  samplingPoint   MicroSamplingPoint @relation(fields: [samplingPointId], references: [id], onDelete: Cascade)
  dayOfWeek       Int // 0=Domingo, 1=Lunes ... 6=Sábado
  isActive        Boolean            @default(true)

  @@unique([samplingPointId, dayOfWeek])
  @@map("micro_schedules")
}

model MicroScheduleEntry {
  id                    String               @id @default(uuid())
  samplingPointId       String               @map("sampling_point_id")
  samplingPoint         MicroSamplingPoint   @relation(fields: [samplingPointId], references: [id], onDelete: Cascade)
  plannedDate           DateTime             @map("planned_date")
  plannedTime           String?              @map("planned_time")
  shift                 String
  workContext           String               @map("work_context")
  workflowType          String               @default("EXTERNAL") @map("workflow_type")
  laboratoryProfile     String               @map("laboratory_profile")
  assignedLab           String?              @map("assigned_lab")
  zoneName              String?              @map("zone_name")
  // @deprecated: usar requestedParameters (junction table MicroScheduleEntryParameter)
  requestedParameterIds Json                 @default("[]") @map("requested_parameter_ids")
  notes                 String?
  status                String               @default("PLANNED")
  statusReason          String?              @map("status_reason")
  // Justificado: log de auditoría con metadata variable por tipo de acción
  statusHistory         Json                 @default("[]") @map("status_history")
  rescheduledFromId     String?              @map("rescheduled_from_id")
  rescheduledFrom       MicroScheduleEntry?  @relation("MicroScheduleEntryReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledEntries    MicroScheduleEntry[] @relation("MicroScheduleEntryReschedule")
  sampleId              String?              @unique @map("sample_id")
  sample                MicroSample?         @relation("MicroSampleScheduleEntry", fields: [sampleId], references: [id], onDelete: SetNull)
  createdById           String?              @map("created_by_id")
  createdBy             User?                @relation("MicroScheduleEntryCreator", fields: [createdById], references: [id])
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  requestedParameters MicroScheduleEntryParameter[]

  @@unique([samplingPointId, plannedDate, shift, workContext, laboratoryProfile], map: "micro_schedule_entries_point_date_shift_context_profile_key")
  @@index([plannedDate])
  @@index([status])
  @@index([samplingPointId, plannedDate])
  @@index([rescheduledFromId])
  @@map("micro_schedule_entries")
}

model MicroSample {
  id              String             @id @default(uuid())
  sampleNumber    String             @unique // MIC-001, MIC-002...
  samplingPointId String
  samplingPoint   MicroSamplingPoint @relation(fields: [samplingPointId], references: [id])

  takenAt   DateTime @default(now())
  takenById String
  takenBy   User     @relation("MicroSampleTaker", fields: [takenById], references: [id])

  lotNumber             String?
  batchCode             String?
  sampleDescription     String?
  workflowType          String    @default("EXTERNAL") @map("workflow_type")
  workContext           String?   @map("work_context")
  shift                 String?
  zoneName              String?   @map("zone_name")
  laboratoryProfile     String?   @map("laboratory_profile")
  // @deprecated: usar requestedParameters (junction table MicroSampleParameter)
  requestedParameterIds Json      @default("[]") @map("requested_parameter_ids")
  dispatchAt            DateTime? @map("dispatch_at")
  dispatchReference     String?   @map("dispatch_reference")
  dispatchObservations  String?   @map("dispatch_observations")
  resultsReceivedAt     DateTime? @map("results_received_at")
  receivedAt            DateTime? @map("received_at")
  resultsCapturedAt     DateTime? @map("results_captured_at")
  reviewedAt            DateTime? @map("reviewed_at")
  productionContextData Json?     @map("production_context_data")
  acceptanceData        Json?     @map("acceptance_data")
  sampleTypeData        Json?     @map("sample_type_data")
  analysisExecutionData Json?     @map("analysis_execution_data")
  technicalReviewData   Json?     @map("technical_review_data")
  approvalData          Json?     @map("approval_data")
  deviationData         Json?     @map("deviation_data")

  lab          String? // Biotrends, Confía Control, UniNacional
  reportNumber String? // M-26-27561-0
  reportUrl    String? // PDF uploaded

  status          String    @default("PENDING") // PENDING, RECEIVED, COMPLETED
  notes           String?
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  closedAt        DateTime? @map("closed_at")
  finalConclusion String?   @map("final_conclusion")
  finalReportData Json?     @map("final_report_data")

  results             MicroResult[]
  attachments         MicroSampleAttachment[]
  scheduleEntry       MicroScheduleEntry?     @relation("MicroSampleScheduleEntry")
  internalLogs        MicroInternalLog[]
  requestedParameters MicroSampleParameter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([samplingPointId])
  @@index([takenAt])
  @@index([status])
  @@index([workflowType])
  @@index([closedAt])
  @@map("micro_samples")
}

model MicroInternalLog {
  id           String      @id @default(uuid())
  sampleId     String      @map("sample_id")
  sample       MicroSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  logDate      DateTime    @map("log_date")
  dayNumber    Int?        @map("day_number")
  observations String?
  // @deprecated: usar logReadings (tabla MicroLogReading)
  readings     Json        @default("[]")
  recordedById String      @map("recorded_by_id")
  recordedBy   User        @relation("MicroInternalLogRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  logReadings MicroLogReading[]

  @@unique([sampleId, logDate])
  @@index([sampleId])
  @@index([logDate])
  @@map("micro_internal_logs")
}

model MicroSampleAttachment {
  id       String      @id @default(uuid())
  sampleId String      @map("sample_id")
  sample   MicroSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  category     String
  originalName String  @map("original_name")
  storedName   String  @map("stored_name")
  mimeType     String? @map("mime_type")
  sizeBytes    Int?    @map("size_bytes")
  url          String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sampleId])
  @@index([sampleId, category])
  @@map("micro_sample_attachments")
}

model MicroResult {
  id          String         @id @default(uuid())
  sampleId    String
  sample      MicroSample    @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  parameterId String
  parameter   MicroParameter @relation(fields: [parameterId], references: [id])

  value       Float? // Numeric value (e.g. 10, 15100000)
  valueText   String? // Text value for qualitative ("Ausente", "<10")
  isDetected  Boolean? // For presence/absence tests (Salmonella)
  isCompliant Boolean? // Auto-calculated: within spec?

  notes String?

  createdAt DateTime @default(now())

  @@unique([sampleId, parameterId])
  @@index([sampleId])
  @@index([parameterId])
  @@map("micro_results")
}

// Junction M2M: MicroScheduleEntry ↔ MicroParameter
model MicroScheduleEntryParameter {
  id          String             @id @default(uuid())
  entryId     String             @map("entry_id")
  entry       MicroScheduleEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  parameterId String             @map("parameter_id")
  parameter   MicroParameter     @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([entryId, parameterId])
  @@index([entryId])
  @@map("micro_schedule_entry_parameters")
}

// Junction M2M: MicroSample ↔ MicroParameter
model MicroSampleParameter {
  id          String         @id @default(uuid())
  sampleId    String         @map("sample_id")
  sample      MicroSample    @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  parameterId String         @map("parameter_id")
  parameter   MicroParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([sampleId, parameterId])
  @@index([sampleId])
  @@map("micro_sample_parameters")
}

// Tabla hija: reemplaza MicroInternalLog.readings Json
model MicroLogReading {
  id          String           @id @default(uuid())
  logId       String           @map("log_id")
  log         MicroInternalLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  parameterId String?          @map("parameter_id")
  parameter   MicroParameter?  @relation(fields: [parameterId], references: [id])
  value       String? // Valor numérico como string (e.g. "10", "15100000")
  valueText   String?          @map("value_text") // Cualitativo ("Ausente", "<10")
  isDetected  Boolean?         @map("is_detected")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([logId])
  @@index([parameterId])
  @@map("micro_log_readings")
}

// ═══════════════════════════════════════════════════════════════════
// PROCUREMENT SYSTEM — Purchase Orders, Reception, Lot Tracking
// ═══════════════════════════════════════════════════════════════════

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PAYMENT_PENDING
  PAID
  PARTIALLY_RECEIVED
  RECEIVED
  ACCOUNTING_PENDING
  COMPLETED
  CANCELLED
}

model Supplier {
  id             String  @id @default(uuid())
  siigoId        String  @unique
  name           String
  identification String? // NIT / CC
  email          String?
  phone          String?
  address        String?
  city           String?
  type           String? // Supplier, Customer, Both
  active         Boolean @default(true)

  // Tax configuration per supplier
  ivaRate         Float? // IVA % (e.g. 19.0), null = exempt
  reteFuenteRate  Float? // RetefUente % (e.g. 2.5), null = not applicable
  paymentTermDays Int?   @default(30) // Payment term in days

  // Fiscal confirmation by accounting (security code required)
  fiscalConfigConfirmed Boolean   @default(false)
  fiscalConfigAt        DateTime? @map("fiscal_config_at")
  fiscalConfigById      String?   @map("fiscal_config_by_id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String              @unique // OC-001, OC-002...
  status      PurchaseOrderStatus @default(DRAFT)

  // Supplier from Siigo
  supplierId   String // Siigo customer ID
  supplierName String
  supplierNit  String?
  supplier     Supplier? @relation(fields: [supplierDbId], references: [id])
  supplierDbId String?

  notes         String?
  expectedDate  DateTime? // When delivery is expected
  quotationUrls Json? // Array of uploaded supplier quotation file URLs

  createdById  String
  createdBy    User      @relation("POCreator", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?     @relation("POApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // Cartera (payment) step
  paidById          String?
  paidBy            User?     @relation("POPayer", fields: [paidById], references: [id])
  paidAt            DateTime?
  paymentProofUrls  Json? // Array of payment proof file URLs
  paymentNotes      String?
  paymentSubtotal   Float?    @map("payment_subtotal") // Subtotal before taxes
  paymentIvaAmount  Float?    @map("payment_iva_amount") // IVA amount applied
  paymentReteAmount Float?    @map("payment_rete_amount") // Retefuente amount applied
  paymentTotal      Float?    @map("payment_total") // Final total paid
  paymentIvaRate    Float?    @map("payment_iva_rate") // IVA % used
  paymentReteRate   Float?    @map("payment_rete_rate") // Retefuente % used
  paymentItemCosts  Json?     @map("payment_item_costs") // Per-item {itemId: {totalPay, unitCostPerKg}}

  // Credit purchase flow
  paymentMethod String    @default("CONTADO") @map("payment_method") // "CONTADO" | "CREDITO"
  creditDueDate DateTime? @map("credit_due_date") // Payment deadline for credit purchases
  creditPaid    Boolean   @default(false) @map("credit_paid")
  creditPaidAt  DateTime? @map("credit_paid_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      PurchaseOrderItem[]
  receptions Reception[]

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId         String? // FK to Product table
  product           Product? @relation("POItemProduct", fields: [productId], references: [id])
  siigoProductCode  String // SKU from Siigo (e.g. MP2F01)
  siigoProductName  String // Human name (e.g. AZUCAR)
  unit              String   @default("gramo") // Always grams internally
  packagingQtyGrams Int? // Conversion: 1 bulto = 50000g
  packagingDesc     String? // "Bulto 50kg", "Caja 25kg"

  quantityOrdered  Int // Total grams ordered
  quantityReceived Int    @default(0) // Accumulated received grams
  unitCost         Float? // Cost per gram (accounting only)

  receptionItems ReceptionItem[]
  lots           MaterialLot[]

  @@index([purchaseOrderId])
  @@index([siigoProductCode])
  @@map("purchase_order_items")
}

enum ReceptionStatus {
  PENDING
  RECEIVED
  ACCOUNTING_REVIEW
  LOTS_PENDING
  COMPLETED
}

model Reception {
  id              String          @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  status          ReceptionStatus @default(PENDING)

  // Logistics
  receivedById       String
  receivedBy         User     @relation("ReceptionReceiver", fields: [receivedById], references: [id])
  receivedAt         DateTime @default(now())
  // photoProductUrl y photoInvoiceUrl eliminados (Fase 8) — eran campos legacy sin uso
  invoiceImageUrls   Json? // Array of invoice photo URLs
  receptionPhotoUrls Json? // Array of reception + product photo URLs
  observations       String?

  // Accounting validation
  accountingUserId      String?
  accountingUser        User?     @relation("ReceptionValidator", fields: [accountingUserId], references: [id])
  accountingAt          DateTime?
  siigoRef              String? // Reference from Siigo registration
  siigoPurchaseId       String? // Siigo purchase invoice ID
  siigoScreenshotUrl    String? // Screenshot of Siigo entry
  accountingNotes       String?
  providerInvoiceNumber String?   @map("provider_invoice_number") // Invoice number from provider
  itemCosts             Json? // Per-item cost data {itemId: {totalPay}}

  items ReceptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
  @@map("receptions")
}

model ReceptionItem {
  id          String            @id @default(uuid())
  receptionId String
  reception   Reception         @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   PurchaseOrderItem @relation(fields: [orderItemId], references: [id])

  quantityExpected Int // What was expected (grams)
  quantityReceived Int // What actually arrived (grams)
  discrepancyNote  String? // If more or less arrived

  @@index([receptionId])
  @@index([orderItemId])
  @@map("reception_items")
}

enum LotStatus {
  AVAILABLE
  LOW_STOCK
  DEPLETED
  EXPIRED
}

model MaterialLot {
  id                  String             @id @default(uuid())
  purchaseOrderItemId String?
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  productId        String? // FK to Product table
  product          Product? @relation("LotProduct", fields: [productId], references: [id])
  siigoProductCode String // SKU (e.g. MP2F01)
  siigoProductName String // Name (e.g. AZUCAR)
  lotNumber        String // Supplier lot number

  initialQuantity Int // Original grams received
  currentQuantity Int // Remaining grams
  unit            String @default("gramo")

  qrData         String? // QR code content
  receivedAt     DateTime  @default(now())
  expiresAt      DateTime? // Expiration date
  status         LotStatus @default(AVAILABLE)
  zone           String    @default("WAREHOUSE") // WAREHOUSE | PRODUCTION
  labelPrinted   Boolean   @default(false)
  labelPrintedAt DateTime?

  zoneTransfers ZoneTransfer[] @relation("ZoneTransferLot")
  consumptions LotConsumption[]
  inventoryCountLines InventoryCountLine[] @relation("InventoryCountLot")


  @@index([siigoProductCode])
  @@index([status])
  @@index([receivedAt])
  @@index([lotNumber])
  @@map("material_lots")
}

model LotConsumption {
  id            String      @id @default(uuid())
  materialLotId String
  materialLot   MaterialLot @relation(fields: [materialLotId], references: [id])

  assemblyNoteId String?      @map("assembly_note_id") // Production note that consumed it
  assemblyNote   AssemblyNote? @relation("NoteConsumptions", fields: [assemblyNoteId], references: [id], onDelete: SetNull)
  quantityUsed   Int // Grams consumed

  usedById     String
  usedBy       User     @relation("LotConsumer", fields: [usedById], references: [id])
  usedAt       DateTime @default(now())
  observations String?

  @@index([materialLotId])
  @@index([assemblyNoteId])
  @@index([usedAt])
  @@map("lot_consumptions")
}

model ProductPackaging {
  id               String  @id @default(uuid())
  productId        String  @unique // FK to Product table
  product          Product @relation("PackagingProduct", fields: [productId], references: [id])
  siigoProductCode String  @unique // SKU (kept for convenience)
  packagingDesc    String // "Bulto 50kg"
  gramsPerUnit     Int // 50000

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_packagings")
}

model ForecastConfig {
  id          String  @id @default(uuid())
  key         String  @unique // e.g. "inventory_weeks", "buffer_pct"
  value       String // "3", "15"
  description String?

  updatedAt DateTime @updatedAt

  @@map("forecast_configs")
}

model ForecastAlert {
  id        String   @id @default(uuid())
  sku       String   @unique // Product SKU (e.g. MPSL07)
  name      String   // Product name for quick reference
  alertDate DateTime @default(now()) @map("alert_date") // When deficit was first detected
  resolved  Boolean  @default(false)
  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sku])
  @@index([resolved])
  @@map("forecast_alerts")
}

// ============================================
// PRODUCTION LOT REGISTRY (Imported from Excel)
// ============================================

model ProductionLot {
  id                    String    @id @default(uuid())
  lotCode               String    @unique // Full lot code e.g. "2601051940MA12"
  premixLot             String? // Premix lot e.g. "260105-12"
  flavor                String // Normalized: "Fresa", "Chamoy", etc.
  flavorRaw             String // Original from Excel: "FRESA", "CHAMOY"
  productionDate        DateTime
  mixAssemblyNote       String?
  mixQuantityKg         Float?
  phJarabe              Float?
  bxJarabe              Float?
  conductividad         Float?
  bxPerla               Float?
  tempCoccion           Float?
  tempChiller           Float?
  productionStartAt     DateTime?
  productionEndAt       DateTime?
  productionDurationMin Int?
  productionDurationRaw String?

  protectionLotCode      String?
  protectionQuantityKg   Float?
  protectionPh           Float?
  protectionBx           Float?
  protectionAssemblyNote String?

  alginateLotCode      String?
  pearlGrowthCheckRaw  String?
  pearlGrowthConfirmed Boolean?
  pearlCookTempC       Float?
  pearlCookTimeSec     Float?

  protectionAdded3400 Float?
  protectionAdded1150 Float?
  protectionAdded350  Float?

  damaged3400 Int?
  damaged1150 Int?
  damaged350  Int?

  pesoPerlas             Float?
  units3400              Int? // Tarros 3400g produced (col AA)
  units1150              Int? // Tarros 1150g produced (col AB — 1100g in Excel)
  units350               Int? // Tarros 350g produced  (col AC — 300g in Excel)
  logisticsDeliveredDate DateTime?
  logisticsDeliveredTo   String?
  leader                 String?
  createdAt              DateTime  @default(now())

  @@index([flavor])
  @@index([productionDate])
  @@map("production_lots")
}

// ============================================
// SYRUP LOT REGISTRY (Sirope Geniality - Excel)
// ============================================

model SyrupLot {
  id              String    @id @default(uuid())
  lotCode         String // "260109-1" (NOT unique — same lot, multiple flavors)
  flavor          String // Normalized: "Maracuya", "Fresa"
  flavorRaw       String // Original: "MARACUYA", "FRESA"
  productionDate  DateTime
  mixQuantityKg   Float? // kg mezcla producida
  phJarabe        Float?
  bxJarabe        Float?
  assemblyNote    String? // nota de ensamble
  units1000ml     Int       @default(0)
  units360ml      Int       @default(0)
  units60ml       Int       @default(0)
  delivered1000ml Int       @default(0)
  delivered360ml  Int       @default(0)
  delivered60ml   Int       @default(0)
  deliveryDate    DateTime?
  leader          String?
  createdAt       DateTime  @default(now())

  @@unique([lotCode, flavor, productionDate])
  @@index([flavor])
  @@index([productionDate])
  @@map("syrup_lots")
}

model ZoneTransfer {
  id              String       @id @default(uuid())
  productId       String
  product         Product      @relation("ZoneTransferProduct", fields: [productId], references: [id])
  materialLotId   String?
  materialLot     MaterialLot? @relation("ZoneTransferLot", fields: [materialLotId], references: [id])
  direction       String // IN = bodega→zona | OUT = zona→bodega
  quantity        Float
  unit            String       @default("unidad")
  lotNumber       String?
  transferredById String
  transferredBy   User         @relation("ZoneTransferUser", fields: [transferredById], references: [id])
  observations    String?
  photos          Json?        @default("[]") // Array of photo URLs
  createdAt       DateTime     @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([transferredById])
  @@map("zone_transfers")
}

// ============================================
// FINISHED PRODUCT LOT TRACKING
// ============================================

enum FinishedProductZone {
  PRODUCCION
  PRODUCTO_TERMINADO
  NO_CONFORME
  BODEGA
  CUARENTENA
  MAQUILA
}

enum FinishedLotStatus {
  AVAILABLE
  LOW
  DEPLETED
}

model FinishedLotStock {
  id              String              @id @default(uuid())
  productId       String
  product         Product             @relation("FinishedLotProduct", fields: [productId], references: [id])
  lotNumber       String
  batchId         String?
  batch           ProductionBatch?    @relation("FinishedLotBatch", fields: [batchId], references: [id])
  zone            FinishedProductZone @default(PRODUCCION)
  initialQuantity Int                 @default(0)
  currentQuantity Int                 @default(0)
  expiresAt       DateTime?
  status          FinishedLotStatus   @default(AVAILABLE)
  labelPrinted    Boolean             @default(false)
  labelPrintedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  transfers FinishedLotTransfer[] @relation("TransferFromStock")

  @@unique([productId, lotNumber, zone])
  @@index([productId, zone])
  @@index([zone, status])
  @@index([lotNumber])
  @@map("finished_lot_stock")
}

model FinishedLotTransfer {
  id                 String              @id @default(uuid())
  finishedLotStockId String?
  finishedLotStock   FinishedLotStock?   @relation("TransferFromStock", fields: [finishedLotStockId], references: [id])
  productId          String
  product            Product             @relation("FinishedLotTransferProduct", fields: [productId], references: [id])
  lotNumber          String
  fromZone           FinishedProductZone
  toZone             FinishedProductZone
  quantity           Int
  reason             String? // "Entrega a logística", "Producto dañado", etc.
  orderId            String? // If consumed for an order (picking)
  transferredById    String
  transferredBy      User                @relation("FinishedLotTransferUser", fields: [transferredById], references: [id])
  observations       String?
  createdAt          DateTime            @default(now())

  @@index([productId, lotNumber])
  @@index([fromZone, toZone])
  @@index([orderId])
  @@index([createdAt])
  @@map("finished_lot_transfers")
}

// ============================================
// HANDOFFS (ENTREGAS PRODUCCIÓN -> BODEGA)
// ============================================

enum HandoffStatus {
  PENDING
  COMPLETED
  REJECTED
}

model ProductHandoff {
  id            String              @id @default(uuid())
  handoffNumber String              @unique // Ej: ENT-260325-01
  fromZone      FinishedProductZone @default(PRODUCCION)
  toZone        FinishedProductZone @default(PRODUCTO_TERMINADO)

  createdById String
  createdBy   User   @relation("HandoffCreator", fields: [createdById], references: [id])

  receivedById String?
  receivedBy   User?   @relation("HandoffReceiver", fields: [receivedById], references: [id])

  status HandoffStatus @default(PENDING)
  notes  String?

  items HandoffItem[]

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("product_handoffs")
}

model HandoffItem {
  id        String         @id @default(uuid())
  handoffId String
  handoff   ProductHandoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation("HandoffProduct", fields: [productId], references: [id])
  lotNumber String

  requestedQuantity Int
  receivedQuantity  Int? // En caso de diferencias

  @@unique([handoffId, productId, lotNumber])
  @@index([handoffId])
  @@map("handoff_items")
}

// ============================================
// PENDING BOX — Multi-Lot Label System
// ============================================

model PendingBox {
  id         String           @id @default(uuid())
  productId  String
  product    Product          @relation("PendingBoxProduct", fields: [productId], references: [id])
  boxSize    Int // units per box (e.g. 6, 40)
  isMaquila  Boolean          @default(false)
  // entries Json ELIMINADO (Fase 4) — normalizado a tabla PendingBoxEntry
  currentQty Int // sum of all entry quantities
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  entries    PendingBoxEntry[]

  @@index([productId, boxSize])
  @@map("pending_boxes")
}

model PendingBoxEntry {
  id        String     @id @default(uuid())
  boxId     String     @map("box_id")
  box       PendingBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  lot       String
  qty       Int
  expiry    DateTime?
  createdAt DateTime   @default(now())

  @@index([boxId])
  @@map("pending_box_entries")
}

// ============================================
// PHYSICAL INVENTORY COUNT
// ============================================

enum PhysicalCountStatus {
  IN_PROGRESS
  CLOSED
}

model PhysicalCount {
  id           String              @id @default(uuid())
  zone         FinishedProductZone @default(PRODUCTO_TERMINADO)
  status       PhysicalCountStatus @default(IN_PROGRESS)
  countedById  String
  countedBy    User                @relation("PhysicalCountUser", fields: [countedById], references: [id])
  checklist    Json // { empaqueConfirmed, pedidosSeparated, noTransfersPending }
  observations String?
  startedAt    DateTime            @default(now())
  closedAt     DateTime?
  items        PhysicalCountItem[]

  @@index([zone, status])
  @@index([startedAt])
  @@map("physical_counts")
}

model PhysicalCountItem {
  id              String        @id @default(uuid())
  physicalCountId String
  physicalCount   PhysicalCount @relation(fields: [physicalCountId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation("PhysicalCountProduct", fields: [productId], references: [id])
  systemQuantity  Int // Stock del sistema al momento del conteo
  countedBoxes    Int           @default(0)
  countedLoose    Int           @default(0)
  countedTotal    Int           @default(0) // boxes * packSize + loose
  difference      Int           @default(0) // countedTotal - systemQuantity
  observations    String?

  @@unique([physicalCountId, productId])
  @@map("physical_count_items")
}

// ============================================
// INVENTARIO FÍSICO MENSUAL (CIERRE DE MES)
// ============================================

enum InventoryCountStatus {
  IN_PROGRESS
  CLOSED
}

model InventoryCountSession {
  id            String               @id @default(uuid())
  sessionCode   String               @unique // IC-202604-BODEGA-PRINCIPAL
  month         String               // "2026-04" (YYYY-MM)
  warehouseName String               @map("warehouse_name") // "Bodega Principal", "Cuarto Frío"
  type          String               @default("MATERIA_PRIMA") @map("type") // "MATERIA_PRIMA" | "PRODUCTO_TERMINADO"
  status        InventoryCountStatus @default(IN_PROGRESS)
  observations  String?
  createdById   String               @map("created_by_id")
  createdBy     User                 @relation("InventoryCountCreator", fields: [createdById], references: [id])
  closedAt      DateTime?            @map("closed_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  lines InventoryCountLine[]

  @@index([month, warehouseName])
  @@index([status])
  @@map("inventory_count_sessions")
}

model InventoryCountLine {
  id        String               @id @default(uuid())
  sessionId String               @map("session_id")
  session   InventoryCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  productId        String?  @map("product_id")
  product          Product? @relation("InventoryCountProduct", fields: [productId], references: [id])
  productName      String   @map("product_name") // snapshot del nombre
  siigoProductCode String?  @map("siigo_product_code")

  lotId      String?     @map("lot_id")
  materialLot MaterialLot? @relation("InventoryCountLot", fields: [lotId], references: [id])
  lotNumber  String      @map("lot_number") // número de lote físico

  physicalQty Float   @map("physical_qty") // cantidad contada físicamente (gramos o unidades)
  unit        String  @default("gramo")   // "gramo" | "unidad"

  // Snapshot al momento del conteo
  siigoQty  Float? @map("siigo_qty")  // Stock Siigo capturado automáticamente o ingresado manual
  // systemQty se calcula en tiempo real desde MaterialLot.currentQuantity (no se persiste)

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sessionId])
  @@index([productId])
  @@map("inventory_count_lines")
}

// ============================================
// MODULO POES (SANEAMIENTO / LAVADO Y DESINFECCION)
// ============================================

model SanitationArea {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String?
  productionLine String   @default("GENERAL") @map("production_line") // SIROPES, PERLAS, GENERAL
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  records    SanitationRecord[]
  components SanitationComponent[]

  @@map("sanitation_areas")
}

model SanitationComponent {
  id        String   @id @default(uuid())
  areaId    String   @map("area_id")
  name      String // e.g. "Tolva de inyección"
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  area       SanitationArea        @relation(fields: [areaId], references: [id])
  checkItems SanitationCheckItem[]

  @@index([areaId])
  @@map("sanitation_components")
}

model SanitationCheckItem {
  id          String    @id @default(uuid())
  recordId    String    @map("record_id")
  componentId String    @map("component_id")
  checked     Boolean   @default(false)
  photoUrl    String?   @map("photo_url")
  checkedAt   DateTime? @map("checked_at")

  record    SanitationRecord    @relation(fields: [recordId], references: [id], onDelete: Cascade)
  component SanitationComponent @relation(fields: [componentId], references: [id])

  @@index([recordId])
  @@map("sanitation_check_items")
}

model SanitationChemical {
  id              String   @id @default(uuid())
  name            String   @unique
  type            String // 'DETERGENTE' | 'DESINFECTANTE'
  activePrinciple String?  @map("active_principle")
  standardDose    String?  @map("standard_dose") // e.g. "2%", "200 ppm"
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  detergentRecords    SanitationRecord[] @relation("DetergentChemical")
  disinfectantRecords SanitationRecord[] @relation("DisinfectantChemical")

  @@map("sanitation_chemicals")
}

model SanitationRecord {
  id     String @id @default(uuid())
  areaId String @map("area_id")
  type   String // 'PRE_OPERACIONAL' | 'INTERMEDIO' | 'POST_OPERACIONAL' | 'PROFUNDO'

  performedById String  @map("performed_by_id")
  verifiedById  String? @map("verified_by_id")

  startedAt   DateTime @map("started_at")
  completedAt DateTime @map("completed_at")

  // Detalles del Detergente
  detergentId          String? @map("detergent_id")
  detergentDose        String? @map("detergent_dose")
  detergentTimeMinutes Int?    @map("detergent_time_minutes")

  // Detalles del Desinfectante
  disinfectantId          String? @map("disinfectant_id")
  disinfectantDose        String? @map("disinfectant_dose")
  disinfectantTimeMinutes Int?    @map("disinfectant_time_minutes")

  photoUrl     String? @map("photo_url")
  observations String?
  status       String  @default("COMPLETED") // COMPLETED, VERIFIED

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  area         SanitationArea        @relation(fields: [areaId], references: [id])
  performedBy  User                  @relation("PerformedSanitation", fields: [performedById], references: [id])
  verifiedBy   User?                 @relation("VerifiedSanitation", fields: [verifiedById], references: [id])
  detergent    SanitationChemical?   @relation("DetergentChemical", fields: [detergentId], references: [id])
  disinfectant SanitationChemical?   @relation("DisinfectantChemical", fields: [disinfectantId], references: [id])
  checkItems   SanitationCheckItem[]

  @@index([areaId])
  @@index([startedAt])
  @@index([status])
  @@map("sanitation_records")
}
