// ═══════════════════════════════════════════════════════════════════════════════
// Academia Popping Boba — Escuela de Líderes
// ═══════════════════════════════════════════════════════════════════════════════

enum AcademiaPilarType {
  TECNICO
  LIDERAZGO
  GESTION
  ERP
}

enum AcademiaLessonType {
  VIDEO
  TEXTO
  INFOGRAFIA
  CASO_ESTUDIO
  PRACTICA
}

enum AcademiaQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum AcademiaCertificationLevel {
  BRONCE
  PLATA
  ORO
  MAESTRO
}

enum AcademiaEnrollmentStatus {
  ACTIVO
  COMPLETADO
  PAUSADO
  RETIRADO
}

enum AcademiaPracticalEvalStatus {
  PENDIENTE
  EN_PROCESO
  APROBADA
  RECHAZADA
}

enum AcademiaBonusStatus {
  PENDIENTE
  APROBADO
  PAGADO
  CANCELADO
}

model AcademiaCourse {
  id          String              @id @default(uuid())
  pilar       AcademiaPilarType
  code        String              @unique
  title       String
  description String?
  sortOrder   Int                 @default(0) @map("sort_order")
  active      Boolean             @default(true)
  createdById String?             @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  createdBy User?              @relation("AcademiaCourseCreator", fields: [createdById], references: [id])
  modules   AcademiaModule[]

  @@index([pilar, active])
  @@map("academia_courses")
}

model AcademiaModule {
  id              String   @id @default(uuid())
  courseId        String   @map("course_id")
  code            String   @unique
  title           String
  description     String?
  estimatedHours  Float    @default(2) @map("estimated_hours")
  sortOrder       Int      @default(0) @map("sort_order")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  course      AcademiaCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     AcademiaLesson[]
  quiz        AcademiaQuiz?
  practicals  AcademiaPracticalEval[]
  rubrics     AcademiaRubric[]
  progress    AcademiaProgress[]

  @@index([courseId, sortOrder])
  @@map("academia_modules")
}

model AcademiaLesson {
  id            String              @id @default(uuid())
  moduleId      String              @map("module_id")
  title         String
  type          AcademiaLessonType  @default(TEXTO)
  contentText   String?             @map("content_text")
  videoUrl      String?             @map("video_url")
  attachmentUrl String?             @map("attachment_url")
  durationMin   Int?                @map("duration_min")
  sortOrder     Int                 @default(0) @map("sort_order")
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  module   AcademiaModule          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress AcademiaLessonProgress[]

  @@index([moduleId, sortOrder])
  @@map("academia_lessons")
}

model AcademiaQuiz {
  id            String   @id @default(uuid())
  moduleId      String   @unique @map("module_id")
  title         String
  passingScore  Int      @default(80) @map("passing_score")
  timeLimitMin  Int?     @map("time_limit_min")
  maxAttempts   Int      @default(3) @map("max_attempts")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  module    AcademiaModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions AcademiaQuestion[]
  attempts  AcademiaQuizAttempt[]

  @@map("academia_quizzes")
}

model AcademiaQuestion {
  id          String                @id @default(uuid())
  quizId      String                @map("quiz_id")
  type        AcademiaQuestionType  @default(MULTIPLE_CHOICE)
  prompt      String
  options     Json?
  correctAnswer Json                @map("correct_answer")
  explanation String?
  points      Int                   @default(10)
  sortOrder   Int                   @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at")

  quiz AcademiaQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("academia_questions")
}

model AcademiaQuizAttempt {
  id          String   @id @default(uuid())
  quizId      String   @map("quiz_id")
  userId      String   @map("user_id")
  startedAt   DateTime @default(now()) @map("started_at")
  submittedAt DateTime? @map("submitted_at")
  answers     Json?
  score       Float?
  passed      Boolean  @default(false)
  attemptNo   Int      @default(1) @map("attempt_no")

  quiz AcademiaQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User         @relation("AcademiaQuizUser", fields: [userId], references: [id])

  @@index([userId, quizId])
  @@index([quizId])
  @@map("academia_quiz_attempts")
}

model AcademiaEnrollment {
  id           String                    @id @default(uuid())
  userId       String                    @map("user_id")
  status       AcademiaEnrollmentStatus  @default(ACTIVO)
  startedAt    DateTime                  @default(now()) @map("started_at")
  completedAt  DateTime?                 @map("completed_at")
  notes        String?
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  user User @relation("AcademiaStudent", fields: [userId], references: [id])

  @@unique([userId])
  @@index([status])
  @@map("academia_enrollments")
}

model AcademiaProgress {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  moduleId            String    @map("module_id")
  lessonsCompleted    Int       @default(0) @map("lessons_completed")
  totalLessons        Int       @default(0) @map("total_lessons")
  quizPassed          Boolean   @default(false) @map("quiz_passed")
  quizBestScore       Float?    @map("quiz_best_score")
  practicalApproved   Boolean   @default(false) @map("practical_approved")
  practicalBestScore  Float?    @map("practical_best_score")
  moduleCompleted     Boolean   @default(false) @map("module_completed")
  completedAt         DateTime? @map("completed_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  module AcademiaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@map("academia_progress")
}

model AcademiaLessonProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  viewedAt    DateTime  @default(now()) @map("viewed_at")
  completedAt DateTime? @map("completed_at")
  timeSpentSec Int      @default(0) @map("time_spent_sec")

  lesson AcademiaLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("academia_lesson_progress")
}

model AcademiaRubric {
  id          String   @id @default(uuid())
  moduleId    String   @map("module_id")
  criterion   String
  description String?
  maxPoints   Int      @default(10) @map("max_points")
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  module AcademiaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, sortOrder])
  @@map("academia_rubrics")
}

model AcademiaPracticalEval {
  id            String                       @id @default(uuid())
  userId        String                       @map("user_id")
  moduleId      String                       @map("module_id")
  evaluatorId   String                       @map("evaluator_id")
  status        AcademiaPracticalEvalStatus  @default(PENDIENTE)
  scoreTotal    Float?                       @map("score_total")
  scoreMax      Float?                       @map("score_max")
  scorePct      Float?                       @map("score_pct")
  scoreDetail   Json?                        @map("score_detail")
  observations  String?
  evidenceUrl   String?                      @map("evidence_url")
  evaluatedAt   DateTime?                    @map("evaluated_at")
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")

  module    AcademiaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user      User           @relation("AcademiaPracticalStudent", fields: [userId], references: [id])
  evaluator User           @relation("AcademiaPracticalEvaluator", fields: [evaluatorId], references: [id])

  @@index([userId, moduleId])
  @@index([status])
  @@map("academia_practical_evals")
}

model AcademiaCertification {
  id           String                      @id @default(uuid())
  userId       String                      @map("user_id")
  level        AcademiaCertificationLevel
  totalScore   Float                       @map("total_score")
  scoreBreakdown Json?                     @map("score_breakdown")
  awardedAt    DateTime                    @default(now()) @map("awarded_at")
  validUntil   DateTime?                   @map("valid_until")
  certificateUrl String?                   @map("certificate_url")
  notes        String?

  user User @relation("AcademiaCertifiedUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([level])
  @@map("academia_certifications")
}

model AcademiaBonus {
  id           String              @id @default(uuid())
  userId       String              @map("user_id")
  awardedById  String              @map("awarded_by_id")
  reason       String
  amountCop    Float               @map("amount_cop")
  status       AcademiaBonusStatus @default(PENDIENTE)
  periodFrom   DateTime?           @map("period_from")
  periodTo     DateTime?           @map("period_to")
  metricSnapshot Json?             @map("metric_snapshot")
  paidAt       DateTime?           @map("paid_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  user      User @relation("AcademiaBonusUser", fields: [userId], references: [id])
  awardedBy User @relation("AcademiaBonusAwarder", fields: [awardedById], references: [id])

  @@index([userId, status])
  @@map("academia_bonuses")
}
